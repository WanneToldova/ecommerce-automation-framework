# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in values. ".env" is git-ignored.
# Every value has a sensible default in src/config/env.config.ts, so the
# framework runs out of the box; override here when you need to.
# ---------------------------------------------------------------------------

# Target environment. Drives BASE_URL selection in env.config.ts (prod|staging).
TEST_ENV=prod

# Override the base URL directly to point at a different store.
# BASE_URL=https://automationexercise.com

# Browser behaviour
HEADLESS=true
SLOW_MO=0

# Credentials for the login happy-path test.
# Leave blank to have the login happy-path test skip itself automatically.
# To enable it: run the registration test once (it creates an account with the
# password below), then put that account's email here. Example:
#   TEST_USER_EMAIL=wanne.qa.1700000000000@example.com
#   TEST_USER_PASSWORD=Wanne@QA2026
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Logging verbosity: error | warn | info | debug
LOG_LEVEL=info
