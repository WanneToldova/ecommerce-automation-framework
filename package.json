{
  "name": "ecommerce-automation-framework",
  "version": "1.0.0",
  "description": "Playwright + TypeScript test automation framework for the Simply Be e-commerce site",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:auth": "playwright test tests/auth",
    "test:catalog": "playwright test tests/catalog",
    "test:cart": "playwright test tests/cart",
    "test:chromium": "playwright test --project=chromium",
    "report": "playwright show-report reports/html",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\""
  },
  "keywords": [
    "playwright",
    "typescript",
    "test-automation",
    "qa",
    "ecommerce",
    "page-object-model"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-playwright": "^2.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "dependencies": {
    "@faker-js/faker": "^9.3.0",
    "dotenv": "^16.4.7",
    "winston": "^3.17.0"
  }
}
